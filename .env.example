# ============================================================
# Financial NLP Chatbot -- Environment Configuration (Template)
# ============================================================
# Copy this file to .env and fill in your actual keys.
# ============================================================

# --- API Keys ---
GEMINI_API_KEY=your_gemini_api_key_here
FMP_API_KEY=your_fmp_api_key_here

# --- Model Paths ---
INTENT_MODEL_PATH=models/intent_classifier/baseline/model.pkl
INTENT_VECTORIZER_PATH=models/intent_classifier/baseline/vectorizer.pkl
BERT_MODEL_PATH=models/intent_classifier/bert/saved_model
NER_MODEL_PATH=models/ner/saved_model

# --- Thresholds ---
INTENT_CONFIDENCE_THRESHOLD=0.85

# --- Feature Flags ---
USE_BERT=false
USE_GEMINI=false
