# ============================================================
# Financial NLP Chatbot — Environment Configuration (Template)
# ============================================================
# Copy this file to .env and fill in your actual keys:
#     copy .env.example .env        (Windows)
#     cp .env.example .env          (macOS/Linux)
#
# IMPORTANT: Never commit .env to version control.
# ============================================================

# --- API Keys ---
# Google Gemini API key (for AI fallback on complex queries)
GEMINI_API_KEY=your_gemini_api_key_here

# Groq API key (optional — used as Gemini fallback)
GROQ_API_KEY=your_groq_api_key_here

# Financial Modeling Prep API key (optional — used for stock data fallback)
FMP_API_KEY=your_fmp_api_key_here

# --- Model Paths (relative to project root) ---
INTENT_MODEL_PATH=models/intent_classifier/baseline/model.pkl
INTENT_VECTORIZER_PATH=models/intent_classifier/baseline/vectorizer.pkl
BERT_MODEL_PATH=models/intent_classifier/bert/saved_model
NER_MODEL_PATH=models/ner/saved_model

# --- Thresholds ---
# Minimum confidence score for intent classification (0.0 - 1.0)
INTENT_CONFIDENCE_THRESHOLD=0.85

# --- Feature Flags ---
# Set to "true" to enable, "false" to disable
USE_BERT=false
USE_GEMINI=false
SAVE_CHAT_HISTORY=false

# --- MongoDB ---
# Connection string for MongoDB (local or Atlas)
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=finchat

# --- JWT Authentication ---
# IMPORTANT: Change this to a strong random secret in production!
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-this-secret-in-production-please
JWT_EXPIRE_MINUTES=10080

# --- Server ---
API_HOST=127.0.0.1
API_PORT=8000

# --- CORS (comma-separated allowed origins) ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8501
